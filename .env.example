# Copy this file to `.env` or run `python3 scripts/personal_crm_install_wizard.py`.
# Never commit `.env`.

PERSONAL_CRM_VAULT=~/Documents/Obsidian/Personal CRM

# Feishu / Lark custom app credentials.
# Find these in Feishu Open Platform -> Your app -> Credentials & Basic Info.
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Optional: only needed when your Feishu callback setup requires them.
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
